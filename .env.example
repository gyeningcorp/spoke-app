# ---- Cloudflare Worker secrets (set via `wrangler secret put NAME`) ----
# Google Gemini API key (for transcription — Gemini 2.5 Flash-Lite native audio)
GEMINI_KEY=your-gemini-api-key-here

# Anthropic Claude API key (for outline/summary — claude-haiku-4-5-20251001)
CLAUDE_KEY=sk-ant-your-claude-api-key-here

# Stripe secret key (for checkout + subscription validation)
STRIPE_KEY=sk_live_or_test_your-stripe-secret-key-here

# JWT signing secret (any long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Stripe price ID for the Pro plan ($9.99/mo)
STRIPE_PRICE_ID=price_your_pro_price_id

# ---- Frontend build-time (Vite) ----
# Public URL of the deployed Cloudflare Worker proxy
VITE_PROXY_URL=https://voicenotes-proxy.your-subdomain.workers.dev
